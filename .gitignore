```gitignore
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so
*.pyd
*.dll

# Distribution / packaging
.Python
build/
dist/
downloads/
develop-eggs/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# Type checkers
.mypy_cache/
.pyre/
.pytype/

# Linters
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# IDEs
.vscode/
.idea/
*.code-workspace

# OS files
.DS_Store
Thumbs.db

# Environment variables
.env
.env.*
*.env

# Logs
*.log

# Local configuration
.python-version

# pyenv
.pyenv/

# Poetry
poetry.lock

# Pipenv
Pipfile.lock

# Hatch
.hatch/

# PDM
.pdm.toml
.pdm-python
.pdm-build/

# pyinstaller
*.spec
```

